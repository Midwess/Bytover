{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
  },
  "exclude": [
    "node_modules",
    "**/generated/**",
    "**/shared_types/**"
  ],
  "include": ["vite.config.ts"]
}
