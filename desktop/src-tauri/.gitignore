# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Signing keys (never commit!)
/keys/

# Provisioning profiles: dev profile is committed for tauri.conf.dev.json;
# production profile is materialized at build time from a GitHub secret.
*.provisionprofile
!Bytover.provisionprofile
