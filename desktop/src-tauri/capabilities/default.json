{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "send",
    "auth",
    "receive"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:webview:allow-create-webview-window",
    "deep-link:default",
    "core:window:allow-start-dragging",
    "drag:default",
    "core:window:allow-set-size"
  ]
}