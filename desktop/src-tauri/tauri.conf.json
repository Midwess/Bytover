{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bytover",
  "version": "0.1.0",
  "identifier": "com.westrise.bitbridge.desktop",
  "build": {
    "beforeDevCommand": "pnpm web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm web:build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "bytover"
        ]
      }
    },
    "opener": {},
    "autostart": null,
    "updater": {
      "endpoints": ["https://releases.bytover.com/{{target}}/{{arch}}/{{current_version}}"],
      "pubkey": ""
    }
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost tauri:; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https://midwess.sgp1.cdn.digitaloceanspaces.com tauri:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.13"
    }
  }
}
