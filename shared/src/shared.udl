callback interface ShellRuntime {
    void msg_from_native([ByRef] bytes event);
};

namespace shared {
  bytes process_event([ByRef] bytes msg);
  bytes handle_response(u32 id, [ByRef] bytes res);
  bytes view();
};

interface NativeProcessor {
  constructor(ShellRuntime shell);
 
  bytes handle(u32 id, [ByRef] bytes effect);
};
